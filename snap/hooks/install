#!/bin/bash
# Runs once when the snap is first installed.
# Sets snap config defaults; the configure hook fires automatically
# afterwards to generate server.toml.
set -eu

snapctl set \
  neo4j.host=localhost \
  neo4j.port=7687 \
  neo4j.user=neo4j \
  neo4j.password="" \
  server.host=127.0.0.1 \
  server.port=8080 \
  llm.provider=anthropic \
  llm.api-key="" \
  llm.model=claude-sonnet-4-6 \
  llm.base-url=https://api.anthropic.com/v1 \
  llm.max-iterations=20 \
  llm.timeout-secs=120 \
  auth.jwt-secret="" \
  agents.public-url="" \
  docs.dir="" \
  ui.host=127.0.0.1 \
  ui.port=3000
