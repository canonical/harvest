#!/bin/bash
# Runs once when the snap is first installed.
# Sets snap config defaults; the configure hook fires automatically
# afterwards to generate server.toml.
set -eu

snapctl set \
  neo4j.host=localhost \
  neo4j.port=7687 \
  neo4j.user=neo4j \
  neo4j.password="" \
  server.host=127.0.0.1 \
  server.port=8080 \
  agent.max-iterations=20 \
  agent.compaction-threshold-chars=40000 \
  agent.compaction-keep-last=6 \
  auth.jwt-secret="" \
  auth.allow-local-login=true \
  auth.google.client-id="" \
  auth.google.client-secret="" \
  auth.google.redirect-uri="" \
  auth.oidc.issuer-url="" \
  auth.oidc.client-id="" \
  auth.oidc.client-secret="" \
  auth.oidc.redirect-uri="" \
  auth.oidc.display-name="" \
  agents.public-url="" \
  docs.dir="" \
  ui.enable-docs=false \
  ui.host=127.0.0.1 \
  ui.port=3000 \
  log.level=warn
