#!/bin/bash
# Runs after every `snap set harvest ...` invocation.
# Regenerates server.toml from the current snap config values.
set -eu

# ── Read snap config ───────────────────────────────────────────────────────
NEO4J_HOST=$(snapctl get neo4j.host)
NEO4J_PORT=$(snapctl get neo4j.port)
NEO4J_USER=$(snapctl get neo4j.user)
NEO4J_PASSWORD=$(snapctl get neo4j.password)
SERVER_HOST=$(snapctl get server.host)
SERVER_PORT=$(snapctl get server.port)

# Primary LLM provider
LLM_PROVIDER=$(snapctl get llm.provider)
LLM_API_KEY=$(snapctl get llm.api-key)
LLM_MODEL=$(snapctl get llm.model)
LLM_BASE_URL=$(snapctl get llm.base-url)
LLM_TIMEOUT=$(snapctl get llm.timeout-secs)
LLM_MAX_RETRIES=$(snapctl get llm.max-retries)
LLM_PRIORITY=$(snapctl get llm.priority)

# Optional fallback LLM provider
LLM2_PROVIDER=$(snapctl get llm2.provider)
LLM2_API_KEY=$(snapctl get llm2.api-key)
LLM2_MODEL=$(snapctl get llm2.model)
LLM2_BASE_URL=$(snapctl get llm2.base-url)
LLM2_TIMEOUT=$(snapctl get llm2.timeout-secs)
LLM2_MAX_RETRIES=$(snapctl get llm2.max-retries)
LLM2_PRIORITY=$(snapctl get llm2.priority)

# Agent behaviour
AGENT_MAX_ITER=$(snapctl get agent.max-iterations)
AGENT_COMPACT_CHARS=$(snapctl get agent.compaction-threshold-chars)
AGENT_COMPACT_KEEP=$(snapctl get agent.compaction-keep-last)

# Auth
JWT_SECRET=$(snapctl get auth.jwt-secret)
AUTH_LOCAL_LOGIN=$(snapctl get auth.allow-local-login)
GOOGLE_CLIENT_ID=$(snapctl get auth.google.client-id)
GOOGLE_CLIENT_SECRET=$(snapctl get auth.google.client-secret)
GOOGLE_REDIRECT_URI=$(snapctl get auth.google.redirect-uri)
OIDC_ISSUER_URL=$(snapctl get auth.oidc.issuer-url)
OIDC_CLIENT_ID=$(snapctl get auth.oidc.client-id)
OIDC_CLIENT_SECRET=$(snapctl get auth.oidc.client-secret)
OIDC_REDIRECT_URI=$(snapctl get auth.oidc.redirect-uri)
OIDC_DISPLAY_NAME=$(snapctl get auth.oidc.display-name)

# Misc
AGENTS_PUBLIC_URL=$(snapctl get agents.public-url)
DOCS_DIR=$(snapctl get docs.dir)
UI_ENABLE_DOCS=$(snapctl get ui.enable-docs)

# ── Apply defaults ─────────────────────────────────────────────────────────
: "${NEO4J_HOST:=localhost}"
: "${NEO4J_PORT:=7687}"
: "${NEO4J_USER:=neo4j}"
: "${SERVER_HOST:=127.0.0.1}"
: "${SERVER_PORT:=8080}"
: "${LLM_PROVIDER:=anthropic}"
: "${LLM_MODEL:=claude-sonnet-4-6}"
: "${LLM_BASE_URL:=}"
: "${LLM_TIMEOUT:=120}"
: "${LLM_MAX_RETRIES:=3}"
: "${LLM_PRIORITY:=0}"
: "${AGENT_MAX_ITER:=20}"
: "${AGENT_COMPACT_CHARS:=40000}"
: "${AGENT_COMPACT_KEEP:=6}"
: "${AUTH_LOCAL_LOGIN:=true}"
: "${DOCS_DIR:=$SNAP_COMMON/docs}"
: "${UI_ENABLE_DOCS:=false}"

mkdir -p "$SNAP_COMMON" "$DOCS_DIR"

# ── Helper: emit one [[llm]] block ─────────────────────────────────────────
write_llm_block() {
  local provider="$1" api_key="$2" model="$3" base_url="$4" \
        timeout="$5" retries="$6" priority="$7"
  echo ""
  echo "[[llm]]"
  echo "provider     = \"${provider}\""
  echo "api_key      = \"${api_key}\""
  echo "model        = \"${model}\""
  echo "timeout_secs = ${timeout}"
  echo "max_retries  = ${retries}"
  echo "priority     = ${priority}"
  if [ "$provider" = "openai-compatible" ] && [ -n "$base_url" ]; then
    echo "base_url     = \"${base_url}\""
  fi
}

# ── Write server.toml ──────────────────────────────────────────────────────
{
  cat << TOML
[server]
host = "${SERVER_HOST}"
port = ${SERVER_PORT}

[neo4j]
uri      = "bolt://${NEO4J_HOST}:${NEO4J_PORT}"
user     = "${NEO4J_USER}"
password = "${NEO4J_PASSWORD}"
TOML

  write_llm_block \
    "$LLM_PROVIDER" "$LLM_API_KEY" "$LLM_MODEL" "$LLM_BASE_URL" \
    "$LLM_TIMEOUT"  "$LLM_MAX_RETRIES" "$LLM_PRIORITY"

  if [ -n "${LLM2_API_KEY:-}" ]; then
    : "${LLM2_PROVIDER:=anthropic}"
    : "${LLM2_MODEL:=claude-sonnet-4-6}"
    : "${LLM2_BASE_URL:=}"
    : "${LLM2_TIMEOUT:=120}"
    : "${LLM2_MAX_RETRIES:=3}"
    : "${LLM2_PRIORITY:=1}"
    write_llm_block \
      "$LLM2_PROVIDER" "$LLM2_API_KEY" "$LLM2_MODEL" "$LLM2_BASE_URL" \
      "$LLM2_TIMEOUT"  "$LLM2_MAX_RETRIES" "$LLM2_PRIORITY"
  fi

  cat << TOML

[agent]
max_iterations             = ${AGENT_MAX_ITER}
compaction_threshold_chars = ${AGENT_COMPACT_CHARS}
compaction_keep_last       = ${AGENT_COMPACT_KEEP}

[auth]
jwt_secret        = "${JWT_SECRET}"
allow_local_login = ${AUTH_LOCAL_LOGIN}
TOML

  if [ -n "${GOOGLE_CLIENT_ID:-}" ] && \
     [ -n "${GOOGLE_CLIENT_SECRET:-}" ] && \
     [ -n "${GOOGLE_REDIRECT_URI:-}" ]; then
    cat << TOML

[auth.google]
client_id     = "${GOOGLE_CLIENT_ID}"
client_secret = "${GOOGLE_CLIENT_SECRET}"
redirect_uri  = "${GOOGLE_REDIRECT_URI}"
TOML
  fi

  if [ -n "${OIDC_ISSUER_URL:-}" ] && \
     [ -n "${OIDC_CLIENT_ID:-}" ] && \
     [ -n "${OIDC_CLIENT_SECRET:-}" ] && \
     [ -n "${OIDC_REDIRECT_URI:-}" ]; then
    cat << TOML

[auth.oidc]
issuer_url    = "${OIDC_ISSUER_URL}"
client_id     = "${OIDC_CLIENT_ID}"
client_secret = "${OIDC_CLIENT_SECRET}"
redirect_uri  = "${OIDC_REDIRECT_URI}"
TOML
    if [ -n "${OIDC_DISPLAY_NAME:-}" ]; then
      echo "display_name  = \"${OIDC_DISPLAY_NAME}\""
    fi
  fi

  cat << TOML

[agents]
binary_path = "${SNAP}/bin/harvest-agent"
TOML

  if [ -n "${AGENTS_PUBLIC_URL:-}" ]; then
    echo "public_url  = \"${AGENTS_PUBLIC_URL}\""
  fi

  cat << TOML

[documentation]
docs_dir = "${DOCS_DIR}"

[ui]
enable_docs = ${UI_ENABLE_DOCS}
TOML

} > "$SNAP_COMMON/server.toml"

# Restart the server if it is already running.
snapctl restart harvest.serve 2>/dev/null || true
