#!/bin/bash
# Runs after every `snap set harvest ...` invocation.
# Regenerates server.toml from the current snap config values.
set -eu

# ── Read required keys early so validation and the main block share them ───
_NEO4J_PASSWORD=$(snapctl get neo4j.password)
_JWT_SECRET=$(snapctl get auth.jwt-secret)

# ── Validate required keys before touching any config files ────────────────
# Skip on a fresh install (server.toml not yet written) so the install hook
# can set empty defaults without triggering an error.
if [ -f "$SNAP_COMMON/server.toml" ]; then
  _errors=""
  [ -z "$_NEO4J_PASSWORD" ] && _errors="${_errors}  neo4j.password is required\n"
  [ -z "$_JWT_SECRET" ]      && _errors="${_errors}  auth.jwt-secret is required\n"
  if [ -n "$_errors" ]; then
    printf "harvest: missing required configuration:\n%b\nRun: snap set harvest neo4j.password=<pw> auth.jwt-secret=\$(openssl rand -base64 32)\n" "$_errors" >&2
    exit 1
  fi
fi

# ── Read snap config ───────────────────────────────────────────────────────
NEO4J_HOST=$(snapctl get neo4j.host)
NEO4J_PORT=$(snapctl get neo4j.port)
NEO4J_USER=$(snapctl get neo4j.user)
NEO4J_PASSWORD="$_NEO4J_PASSWORD"
SERVER_HOST=$(snapctl get server.host)
SERVER_PORT=$(snapctl get server.port)

# Agent behaviour
AGENT_MAX_ITER=$(snapctl get agent.max-iterations)
AGENT_COMPACT_CHARS=$(snapctl get agent.compaction-threshold-chars)
AGENT_COMPACT_KEEP=$(snapctl get agent.compaction-keep-last)

# Auth
JWT_SECRET="$_JWT_SECRET"
AUTH_LOCAL_LOGIN=$(snapctl get auth.allow-local-login)
GOOGLE_CLIENT_ID=$(snapctl get auth.google.client-id)
GOOGLE_CLIENT_SECRET=$(snapctl get auth.google.client-secret)
GOOGLE_REDIRECT_URI=$(snapctl get auth.google.redirect-uri)
OIDC_ISSUER_URL=$(snapctl get auth.oidc.issuer-url)
OIDC_CLIENT_ID=$(snapctl get auth.oidc.client-id)
OIDC_CLIENT_SECRET=$(snapctl get auth.oidc.client-secret)
OIDC_REDIRECT_URI=$(snapctl get auth.oidc.redirect-uri)
OIDC_DISPLAY_NAME=$(snapctl get auth.oidc.display-name)

# Misc
AGENTS_PUBLIC_URL=$(snapctl get agents.public-url)
DOCS_DIR=$(snapctl get docs.dir)
UI_ENABLE_DOCS=$(snapctl get ui.enable-docs)
LOG_LEVEL=$(snapctl get log.level)

# ── Apply defaults ─────────────────────────────────────────────────────────
: "${NEO4J_HOST:=localhost}"
: "${NEO4J_PORT:=7687}"
: "${NEO4J_USER:=neo4j}"
: "${SERVER_HOST:=127.0.0.1}"
: "${SERVER_PORT:=8080}"
: "${AGENT_MAX_ITER:=20}"
: "${AGENT_COMPACT_CHARS:=40000}"
: "${AGENT_COMPACT_KEEP:=6}"
: "${AUTH_LOCAL_LOGIN:=true}"
: "${DOCS_DIR:=$SNAP_COMMON/docs}"
: "${UI_ENABLE_DOCS:=false}"
: "${LOG_LEVEL:=warn}"

mkdir -p "$SNAP_COMMON" "$DOCS_DIR"

# Write an env file sourced by service/command wrappers at startup.
printf 'RUST_LOG=%s\n' "$LOG_LEVEL" > "$SNAP_COMMON/env"

# ── LLM provider blocks ────────────────────────────────────────────────────
# Read all named providers under llm.* as a JSON document and emit one
# [[llm]] TOML block per provider whose api-key is set.
# The JSON is passed via an environment variable to avoid shell-quoting issues.
generate_llm_blocks() {
  local llm_json
  llm_json=$(snapctl get -d llm 2>/dev/null || echo '{}')
  LLM_JSON="$llm_json" python3 -c '
import json, os, sys

DEFAULTS = {
    "anthropic":         "claude-sonnet-4-6",
    "gemini":            "gemini-2.5-flash",
    "openai-compatible": "",
}

try:
    data = json.loads(os.environ.get("LLM_JSON", "{}"))
except Exception:
    data = {}

if not isinstance(data, dict):
    data = {}

# snapctl get -d llm wraps the result as {"llm": {...}} — unwrap it
providers = data.get("llm", data)
if not isinstance(providers, dict):
    providers = {}

def sort_key(kv):
    _, cfg = kv
    if not isinstance(cfg, dict):
        return (999, kv[0])
    try:
        return (int(str(cfg.get("priority", 0))), kv[0])
    except (ValueError, TypeError):
        return (0, kv[0])

found = 0
for name, cfg in sorted(providers.items(), key=sort_key):
    if not isinstance(cfg, dict):
        continue
    api_key = cfg.get("api-key", "")
    if not api_key:
        continue
    provider = cfg.get("provider", "anthropic")
    model    = cfg.get("model", "") or DEFAULTS.get(provider, "")
    timeout  = cfg.get("timeout-secs", 120)
    retries  = cfg.get("max-retries", 3)
    priority = cfg.get("priority", 0)
    base_url = cfg.get("base-url", "")

    print("")
    print("[[llm]]")
    print("provider     = \"%s\"" % provider)
    print("api_key      = \"%s\"" % api_key)
    if model:
        print("model        = \"%s\"" % model)
    print("timeout_secs = %s" % timeout)
    print("max_retries  = %s" % retries)
    print("priority     = %s" % priority)
    if provider == "openai-compatible" and base_url:
        print("base_url     = \"%s\"" % base_url)
    found += 1
'
}

# ── Write server.toml ──────────────────────────────────────────────────────
{
  cat << TOML
[server]
host = "${SERVER_HOST}"
port = ${SERVER_PORT}

[neo4j]
uri      = "bolt://${NEO4J_HOST}:${NEO4J_PORT}"
user     = "${NEO4J_USER}"
password = "${NEO4J_PASSWORD}"
TOML

  # If no providers are configured yet, write an empty array so the TOML is
  # valid.  The server will refuse to start and print a clear error message.
  llm_blocks=$(generate_llm_blocks)
  if [ -n "$llm_blocks" ]; then
    echo "$llm_blocks"
  else
    echo ""
    echo "llm = []"
  fi

  cat << TOML

[agent]
max_iterations             = ${AGENT_MAX_ITER}
compaction_threshold_chars = ${AGENT_COMPACT_CHARS}
compaction_keep_last       = ${AGENT_COMPACT_KEEP}

[auth]
jwt_secret        = "${JWT_SECRET}"
allow_local_login = ${AUTH_LOCAL_LOGIN}
TOML

  if [ -n "${GOOGLE_CLIENT_ID:-}" ] && \
     [ -n "${GOOGLE_CLIENT_SECRET:-}" ] && \
     [ -n "${GOOGLE_REDIRECT_URI:-}" ]; then
    cat << TOML

[auth.google]
client_id     = "${GOOGLE_CLIENT_ID}"
client_secret = "${GOOGLE_CLIENT_SECRET}"
redirect_uri  = "${GOOGLE_REDIRECT_URI}"
TOML
  fi

  if [ -n "${OIDC_ISSUER_URL:-}" ] && \
     [ -n "${OIDC_CLIENT_ID:-}" ] && \
     [ -n "${OIDC_CLIENT_SECRET:-}" ] && \
     [ -n "${OIDC_REDIRECT_URI:-}" ]; then
    cat << TOML

[auth.oidc]
issuer_url    = "${OIDC_ISSUER_URL}"
client_id     = "${OIDC_CLIENT_ID}"
client_secret = "${OIDC_CLIENT_SECRET}"
redirect_uri  = "${OIDC_REDIRECT_URI}"
TOML
    if [ -n "${OIDC_DISPLAY_NAME:-}" ]; then
      echo "display_name  = \"${OIDC_DISPLAY_NAME}\""
    fi
  fi

  cat << TOML

[agents]
binary_path = "${SNAP}/bin/harvest-agent"
TOML

  if [ -n "${AGENTS_PUBLIC_URL:-}" ]; then
    echo "public_url  = \"${AGENTS_PUBLIC_URL}\""
  fi

  cat << TOML

[documentation]
docs_dir = "${DOCS_DIR}"

[ui]
enable_docs = ${UI_ENABLE_DOCS}
TOML

} > "$SNAP_COMMON/server.toml"

# Restart running services so they pick up the new config.
snapctl restart harvest.server 2>/dev/null || true
snapctl restart harvest.ui   2>/dev/null || true

# ── Write harvester.toml ───────────────────────────────────────────────────
# Repositories are NOT generated here — they live in $SNAP_COMMON/repositories.toml
# (user-managed).  The wrapper-ingest-code script merges both files at runtime.

# Pick the single lowest-priority LLM provider configured for the harvester.
generate_harvester_llm_block() {
  local llm_json
  llm_json=$(snapctl get -d llm 2>/dev/null || echo '{}')
  LLM_JSON="$llm_json" python3 -c '
import json, os, sys

DEFAULTS = {
    "anthropic":         "claude-sonnet-4-6",
    "gemini":            "gemini-2.5-flash",
    "openai-compatible": "",
}

try:
    data = json.loads(os.environ.get("LLM_JSON", "{}"))
except Exception:
    data = {}

providers = data.get("llm", data) if isinstance(data, dict) else {}
if not isinstance(providers, dict):
    providers = {}

def sort_key(kv):
    _, cfg = kv
    if not isinstance(cfg, dict):
        return (999, kv[0])
    try:
        return (int(str(cfg.get("priority", 0))), kv[0])
    except (ValueError, TypeError):
        return (0, kv[0])

for name, cfg in sorted(providers.items(), key=sort_key):
    if not isinstance(cfg, dict):
        continue
    api_key = cfg.get("api-key", "")
    if not api_key:
        continue
    provider = cfg.get("provider", "anthropic")
    model    = cfg.get("model", "") or DEFAULTS.get(provider, "")
    timeout  = cfg.get("timeout-secs", 120)
    retries  = cfg.get("max-retries", 3)
    base_url = cfg.get("base-url", "")

    print("")
    print("[llm]")
    print("provider     = \"%s\"" % provider)
    print("api_key      = \"%s\"" % api_key)
    if model:
        print("model        = \"%s\"" % model)
    print("timeout_secs = %s" % timeout)
    print("max_retries  = %s" % retries)
    if provider == "openai-compatible" and base_url:
        print("base_url     = \"%s\"" % base_url)
    break  # single provider only
'
}

{
  cat << TOML
[neo4j]
uri      = "bolt://${NEO4J_HOST}:${NEO4J_PORT}"
user     = "${NEO4J_USER}"
password = "${NEO4J_PASSWORD}"
TOML

  generate_harvester_llm_block

} > "$SNAP_COMMON/harvester.toml"
