{
	auto_https     off
	admin          off
	persist_config off
}

{env.UI_HOST}:{env.UI_PORT} {
	# Reverse-proxy all API paths to knowledge-server.
	@api path_regexp ^/(auth|admin|conversations|groups|projects|query|repositories|graph|health|tool-description|docs|agents|agent)(/|$)

	handle @api {
		reverse_proxy {env.SERVER_HOST}:{env.SERVER_PORT} {
			header_up Host        {host}
			header_up X-Real-IP   {remote_host}
			# flush_interval -1 disables response buffering, required for SSE streams.
			flush_interval -1
			transport http {
				read_timeout  3600s
				write_timeout 3600s
			}
		}
	}

	# Serve static assets; fall back to index.html for client-side routing.
	handle {
		root * {env.SNAP}/share/harvest-ui
		try_files {path} {path}/ /index.html
		file_server
	}
}
