#!/bin/bash
# Wrapper for the knowledge-server.
# Passes the snap-generated server.toml config and forwards any extra arguments.
set -eu

CONF="$SNAP_COMMON/server.toml"

if [ ! -f "$CONF" ]; then
  echo "error: Harvest server is not configured." >&2
  echo "  snap set harvest neo4j.password=<password> llm.api-key=<key>" >&2
  exit 1
fi

exec "$SNAP/bin/knowledge-server" --config "$CONF" "$@"
