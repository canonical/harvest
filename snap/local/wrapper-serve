#!/bin/bash
# Wrapper for knowledge-server.
# Validates the config is present and exec's the binary.
set -eu

CONF="$SNAP_COMMON/server.toml"

if [ ! -f "$CONF" ]; then
  echo "error: harvest-server is not configured." >&2
  echo "  snap set harvest-server neo4j.password=<pw> llm.api-key=<key> auth.jwt-secret=<secret>" >&2
  exit 1
fi

exec "$SNAP/bin/knowledge-server" --config "$CONF" "$@"
