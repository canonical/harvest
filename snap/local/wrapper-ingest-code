#!/bin/bash
# Wrapper for knowledge-harvester ingest-code (one-shot run).
# Merges $SNAP_COMMON/harvester.toml (generated by the configure hook) with
# a repositories file, then execs knowledge-harvester --config <merged> run.
#
# Usage: harvest.ingest-code [-f /path/to/repositories.toml] [--force]
set -eu

BASE_CONF="$SNAP_COMMON/harvester.toml"
REPOS_CONF="$SNAP_COMMON/repositories.toml"

# -f <file> overrides the repositories file
if [ "${1:-}" = "-f" ] && [ -n "${2:-}" ]; then
    REPOS_CONF="$2"
    shift 2
fi

if [ ! -f "$BASE_CONF" ]; then
    echo "error: harvest is not configured." >&2
    echo "  snap set harvest neo4j.password=<pw> llm.primary.provider=anthropic llm.primary.api-key=<key>" >&2
    exit 1
fi

if [ ! -f "$REPOS_CONF" ]; then
    echo "error: no repositories file found at: $REPOS_CONF" >&2
    echo "  Write [[repositories]] blocks there, or pass -f /path/to/repositories.toml" >&2
    exit 1
fi

TMP=$(mktemp --suffix=.toml)
trap 'rm -f "$TMP"' EXIT
cat "$BASE_CONF" "$REPOS_CONF" > "$TMP"

exec "$SNAP/bin/knowledge-harvester" --config "$TMP" run "$@"
