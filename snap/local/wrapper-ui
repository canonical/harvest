#!/bin/bash
set -eu

UI_HOST=$(snapctl get ui.host)
UI_PORT=$(snapctl get ui.port)
SERVER_HOST=$(snapctl get server.host)
SERVER_PORT=$(snapctl get server.port)

: "${UI_HOST:=127.0.0.1}"
: "${UI_PORT:=3000}"
: "${SERVER_HOST:=127.0.0.1}"
: "${SERVER_PORT:=8080}"

export XDG_DATA_HOME="$SNAP_COMMON"
export XDG_CONFIG_HOME="$SNAP_COMMON"
export XDG_CACHE_HOME="$SNAP_COMMON"

cat > "$SNAP_COMMON/Caddyfile" << EOF
{
	auto_https     off
	admin          off
	persist_config off
}

${UI_HOST}:${UI_PORT} {
	@api path_regexp ^/(auth|admin|conversations|groups|projects|query|repositories|graph|health|tool-description|docs|agents|agent)(/|$)

	handle @api {
		reverse_proxy ${SERVER_HOST}:${SERVER_PORT} {
			header_up Host       {host}
			header_up X-Real-IP  {remote_host}
			flush_interval -1
			transport http {
				read_timeout  3600s
				write_timeout 3600s
			}
		}
	}

	handle {
		root * ${SNAP}/share/harvest-ui
		try_files {path} {path}/ /index.html
		file_server
	}
}
EOF

echo "Harvest UI  →  http://${UI_HOST}:${UI_PORT}"
echo "API server  →  http://${SERVER_HOST}:${SERVER_PORT}"
exec "$SNAP/bin/caddy" run --config "$SNAP_COMMON/Caddyfile"
