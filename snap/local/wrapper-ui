#!/bin/bash
# Wrapper for the web UI.
# Exports snap config values as environment variables and starts Caddy.
# Caddy serves the static Vite build and reverse-proxies all API paths to
# knowledge-server using the Caddyfile at $SNAP/etc/harvest/Caddyfile.
set -eu

UI_HOST=$(snapctl get ui.host)
UI_PORT=$(snapctl get ui.port)
SERVER_HOST=$(snapctl get server.host)
SERVER_PORT=$(snapctl get server.port)

: "${UI_HOST:=127.0.0.1}"
: "${UI_PORT:=3000}"
: "${SERVER_HOST:=127.0.0.1}"
: "${SERVER_PORT:=8080}"

export UI_HOST UI_PORT SERVER_HOST SERVER_PORT SNAP SNAP_COMMON
# Point Caddy's runtime data paths to the writable snap area.
export XDG_DATA_HOME="$SNAP_COMMON"
export XDG_CONFIG_HOME="$SNAP_COMMON"
export XDG_CACHE_HOME="$SNAP_COMMON"

echo "Harvest UI  →  http://${UI_HOST}:${UI_PORT}"
echo "API server  →  http://${SERVER_HOST}:${SERVER_PORT}"
exec "$SNAP/bin/caddy" run --config "$SNAP/etc/harvest/Caddyfile"
