#!/bin/bash
# Wrapper for the knowledge-harvester CLI.
# Merges the snap-managed connection config with the user-managed
# repositories list, then hands off to the real binary.
set -eu

CONNECT="$SNAP_COMMON/harvester-connect.toml"
REPOS="$SNAP_COMMON/repositories.toml"
RUNTIME="$SNAP_COMMON/.harvester-runtime.toml"

if [ ! -f "$CONNECT" ]; then
  echo "error: Harvest is not configured." >&2
  echo "  Configure Neo4j credentials:" >&2
  echo "    snap set harvest neo4j.password=<password>" >&2
  exit 1
fi

if [ ! -f "$REPOS" ] || ! grep -q '^\[\[repositories\]\]' "$REPOS" 2>/dev/null; then
  echo "error: No repositories configured." >&2
  echo "  Add repositories to: $REPOS" >&2
  echo "" >&2
  echo "  Example entry:" >&2
  echo "    [[repositories]]" >&2
  echo '    name = "my-repo"' >&2
  echo '    url  = "https://github.com/my-org/my-repo.git"' >&2
  echo '    refs = ["main"]' >&2
  exit 1
fi

# Concatenate: connection + storage settings, then repository blocks.
cat "$CONNECT" "$REPOS" > "$RUNTIME"

exec "$SNAP/bin/knowledge-harvester" --config "$RUNTIME" "$@"
